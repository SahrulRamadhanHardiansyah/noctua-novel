generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User Profile (extends Clerk identity) ────────────────────────────────────
model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique // Clerk user ID
  displayName    String
  bio            String?  @db.Text
  avatarUrl      String?
  coinBalance    Int      @default(0)
  totalEarnings  Int      @default(0)
  checkInStreak  Int      @default(0)
  lastCheckIn    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  coinTransactions CoinTransaction[]
  dailyCheckIns    DailyCheckIn[]
  readingMissions  ReadingMissionProgress[]

  @@index([userId])
}

// ─── Favorites ────────────────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  novelSlug String
  createdAt DateTime @default(now())

  @@unique([userId, novelSlug])
  @@index([userId])
}

// ─── Comments (Novel-level) ───────────────────────────────────────────────────
model Comment {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String
  novelSlug      String
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([novelSlug])
  @@index([userId])
}

// ─── User Novels (Author-created) ─────────────────────────────────────────────
model UserNovel {
  id          String   @id @default(cuid())
  userId      String
  authorName  String
  slug        String   @unique
  title       String
  synopsis    String?  @db.Text
  imageUrl    String?
  genres      String[]
  status      String   @default("Ongoing")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters    UserChapter[]
  reviews     Review[]

  @@index([userId])
}

// ─── User Chapters ────────────────────────────────────────────────────────────
model UserChapter {
  id             String    @id @default(cuid())
  novelId        String
  slug           String    @unique
  title          String
  content        String    @db.Text
  orderIndex     Int       @default(0)
  isDraft        Boolean   @default(false)
  isLocked       Boolean   @default(false) // Premium chapter
  coinPrice      Int       @default(0)     // Cost in coins to unlock
  scheduledAt    DateTime? // Scheduled publish time
  viewCount      Int       @default(0)
  wordCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  novel          UserNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  inlineComments InlineComment[]
  autoSaves      ChapterAutoSave[]

  @@index([novelId])
}

// ─── Chapter Auto-Save ────────────────────────────────────────────────────────
model ChapterAutoSave {
  id        String   @id @default(cuid())
  chapterId String
  content   String   @db.Text
  title     String?
  savedAt   DateTime @default(now())

  chapter   UserChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

// ─── Inline Comments (per-paragraph, Wattpad-style) ───────────────────────────
model InlineComment {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String?
  chapterId      String
  paragraphIndex Int      // Which paragraph this comment is on
  content        String   @db.Text
  createdAt      DateTime @default(now())

  chapter        UserChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, paragraphIndex])
  @@index([userId])
}

// ─── Reviews & Ratings ────────────────────────────────────────────────────────
model Review {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String?
  novelId        String
  rating         Int      // 1-5 stars
  title          String?
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  novel          UserNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId]) // One review per user per novel
  @@index([novelId])
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("system") // chapter_release | comment_reply | achievement | system | coin
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId])
}

// ─── Coin Transactions ────────────────────────────────────────────────────────
model CoinTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Positive = earn, negative = spend
  type        String   // daily_checkin | reading_mission | chapter_unlock | purchase | author_earning
  description String?
  createdAt   DateTime @default(now())

  profile     UserProfile @relation(fields: [userId], references: [userId])

  @@index([userId])
}

// ─── Daily Check-In ───────────────────────────────────────────────────────────
model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  day       Int      // Day in streak (1-7), rewards scale with streak
  reward    Int      // Coins earned
  checkedAt DateTime @default(now())

  profile   UserProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, checkedAt])
  @@index([userId])
}

// ─── Reading Missions ─────────────────────────────────────────────────────────
model ReadingMission {
  id          String   @id @default(cuid())
  title       String
  description String
  target      Int      // e.g. read 5 chapters
  reward      Int      // Coins earned on completion
  type        String   // daily | weekly
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ReadingMissionProgress {
  id        String   @id @default(cuid())
  userId    String
  missionId String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  claimedAt DateTime?
  updatedAt DateTime @updatedAt

  profile   UserProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, missionId])
  @@index([userId])
}
