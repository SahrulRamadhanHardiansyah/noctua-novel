generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User Profile (extends Clerk identity) ────────────────────────────────────
model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique // Clerk user ID
  displayName    String
  bio            String?  @db.Text
  avatarUrl      String?
  coinBalance    Int      @default(0)
  totalEarnings  Int      @default(0)
  checkInStreak  Int      @default(0)
  lastCheckIn    DateTime?

  // Role
  role           String   @default("USER") // USER | ADMIN

  // Gamification
  xp             Int      @default(0)  // Total XP earned
  level          Int      @default(1)  // Current level
  equippedTitle  String?  // Currently displayed title/gelar
  equippedBorder String?  @default("none") // Currently equipped avatar border

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  coinTransactions     CoinTransaction[]
  dailyCheckIns        DailyCheckIn[]
  readingMissions      ReadingMissionProgress[]
  userAchievements     UserAchievement[]
  unlockedBorders      UserBorder[]
  comments             Comment[]

  @@index([userId])
  @@index([level])
}

// ─── Profile Borders (unlockable) ────────────────────────────────────────────
model ProfileBorder {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "silver_frame", "golden_glow", "violet_aura"
  name        String
  description String
  cssClass    String   // Tailwind classes for the border effect
  requiredLvl Int      @default(1) // Minimum level to unlock
  rarity      String   @default("common") // common | rare | epic | legendary
  createdAt   DateTime @default(now())

  userBorders UserBorder[]
}

model UserBorder {
  id        String   @id @default(cuid())
  userId    String
  borderId  String
  unlockedAt DateTime @default(now())

  profile   UserProfile   @relation(fields: [userId], references: [userId])
  border    ProfileBorder @relation(fields: [borderId], references: [id])

  @@unique([userId, borderId])
  @@index([userId])
}

// ─── User Titles (unlockable gelar) ──────────────────────────────────────────
model UserTitle {
  id            String   @id @default(cuid())
  userId        String
  title         String   // e.g. "The Ancient Reader"
  source        String   // "achievement:night_owl" | "level:10" | "custom"
  unlockedAt    DateTime @default(now())

  @@unique([userId, title])
  @@index([userId])
}

// ─── Favorites ────────────────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  novelSlug String
  createdAt DateTime @default(now())

  @@unique([userId, novelSlug])
  @@index([userId])
}

// ─── Comments (Novel-level) ───────────────────────────────────────────────────
model Comment {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String
  novelSlug      String
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorProfile  UserProfile? @relation(fields: [userId], references: [userId])

  @@index([novelSlug])
  @@index([userId])
}

// ─── User Novels (Author-created) ─────────────────────────────────────────────
model UserNovel {
  id          String   @id @default(cuid())
  userId      String
  authorName  String
  slug        String   @unique
  title       String
  synopsis    String?  @db.Text
  imageUrl    String?
  genres      String[]
  status      String   @default("Ongoing")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters    UserChapter[]
  reviews     Review[]

  @@index([userId])
}

// ─── User Chapters ────────────────────────────────────────────────────────────
model UserChapter {
  id             String    @id @default(cuid())
  novelId        String
  slug           String    @unique
  title          String
  content        String    @db.Text
  orderIndex     Int       @default(0)
  isDraft        Boolean   @default(false)
  isLocked       Boolean   @default(false) // Premium chapter
  coinPrice      Int       @default(0)     // Cost in coins to unlock
  scheduledAt    DateTime? // Scheduled publish time
  viewCount      Int       @default(0)
  wordCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  novel          UserNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  inlineComments InlineComment[]
  autoSaves      ChapterAutoSave[]

  @@index([novelId])
  @@index([novelId, orderIndex])
  @@index([isDraft])
}

// ─── Chapter Auto-Save ────────────────────────────────────────────────────────
model ChapterAutoSave {
  id        String   @id @default(cuid())
  chapterId String
  content   String   @db.Text
  title     String?
  savedAt   DateTime @default(now())

  chapter   UserChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

// ─── Inline Comments (per-paragraph, Wattpad-style) ───────────────────────────
model InlineComment {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String?
  chapterId      String
  paragraphIndex Int      // Which paragraph this comment is on
  content        String   @db.Text
  createdAt      DateTime @default(now())

  chapter        UserChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, paragraphIndex])
  @@index([userId])
}

// ─── Reviews & Ratings ────────────────────────────────────────────────────────
model Review {
  id             String   @id @default(cuid())
  userId         String
  authorName     String
  authorImageUrl String?
  novelId        String
  rating         Int      // 1-5 stars
  title          String?
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  novel          UserNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId]) // One review per user per novel
  @@index([novelId])
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("system") // chapter_release | comment_reply | achievement | system | coin
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId])
}

// ─── Coin Transactions ────────────────────────────────────────────────────────
model CoinTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Positive = earn, negative = spend
  type        String   // daily_checkin | reading_mission | chapter_unlock | purchase | author_earning
  description String?
  createdAt   DateTime @default(now())

  profile     UserProfile @relation(fields: [userId], references: [userId])

  @@index([userId])
}

// ─── Daily Check-In ───────────────────────────────────────────────────────────
model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  day       Int      // Day in streak (1-7), rewards scale with streak
  reward    Int      // Coins earned
  checkedAt DateTime @default(now())

  profile   UserProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, checkedAt])
  @@index([userId])
}

// ─── Reading Missions ─────────────────────────────────────────────────────────
model ReadingMission {
  id          String   @id @default(cuid())
  title       String
  description String
  target      Int      // e.g. read 5 chapters
  reward      Int      // Coins earned on completion
  type        String   // daily | weekly
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ReadingMissionProgress {
  id        String   @id @default(cuid())
  userId    String
  missionId String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  claimedAt DateTime?
  updatedAt DateTime @updatedAt

  profile   UserProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, missionId])
  @@index([userId])
}

// ─── Achievement / Badge System ──────────────────────────────────────────────
model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "night_owl", "marathon_reader", "first_review"
  title       String
  description String
  icon        String   // lucide icon name
  category    String   // reading | social | author | streak
  requirement Int      @default(1) // threshold to unlock
  coinReward  Int      @default(0) // Coins awarded on unlock
  titleReward String?  // Title/gelar awarded on unlock (e.g. "The Ancient Reader")
  xpReward    Int      @default(50) // XP awarded on unlock
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  progress      Int      @default(0)

  profile       UserProfile @relation(fields: [userId], references: [userId])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Bookmarks & Annotations ─────────────────────────────────────────────────
model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  chapterSlug    String
  novelSlug      String
  label          String?  // user-given label
  paragraphIndex Int?     // specific paragraph, null = whole chapter
  highlightText  String?  @db.Text // selected text
  note           String?  @db.Text // user annotation
  color          String   @default("#8b5cf6") // highlight color
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, novelSlug])
  @@index([userId, chapterSlug])
}

// ─── Reading Progress Tracking ───────────────────────────────────────────────
model ReadingProgress {
  id             String   @id @default(cuid())
  userId         String
  chapterSlug    String
  novelSlug      String
  scrollPosition Float    @default(0) // percentage 0-100
  completed      Boolean  @default(false)
  lastReadAt     DateTime @default(now())

  @@unique([userId, chapterSlug])
  @@index([userId, novelSlug])
  @@index([novelSlug])
}

// ─── Chapter View Analytics ──────────────────────────────────────────────────
model ChapterView {
  id         String   @id @default(cuid())
  chapterId  String
  userId     String?  // null for anonymous
  viewedAt   DateTime @default(now())

  @@index([chapterId, viewedAt])
  @@index([userId])
}
